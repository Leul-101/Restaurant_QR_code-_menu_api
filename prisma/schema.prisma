// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp

  @@map("admins")
}

model RestaurantTable {
  id          Int      @id @default(autoincrement())
  tableNumber Int   @unique @map("table_number")
  qrCode      String   @unique @map("qr_code") @default(cuid())
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp
  
  // Relations
  qrScans     QrScan[]

  @@map("restaurant_tables")
}

model QrScan {
  id        Int      @id @default(autoincrement())
  tableId   Int      @map("table_id")
  sessionId String   @map("session_id") @db.Text
  scannedAt DateTime @default(now()) @map("scanned_at") @db.Timestamp
  ipHash    String   @map("ip_hash") @db.Text
  userAgent String?   @map("user_agent") @db.Text

  // Relations
  table     RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  session   Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("qr_scans")
}

model Category {
  id           Int        @id @default(autoincrement())
  name         String     @db.VarChar(100)
  icon         String?    @db.VarChar(50)
  displayOrder Int        @map("display_order") @default(0)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamp
  
  // Relations
  menuItems    MenuItem[]

  @@map("categories")
}

model MenuItem {
  id           Int            @id @default(autoincrement())
  categoryId   Int            @map("category_id")
  name         String         @db.Text
  description  String?         @db.Text
  shortDescription String?     @map("short_description") @db.Text
  price        Decimal        @db.Decimal(10, 2)
  imageUrl     String?         @map("image_url") @db.Text
  isAvailable  Boolean        @default(true) @map("is_available")
  showHome     Boolean        @default(false) @map("show_home")
  displayOrder Int            @map("display_order") @default(0)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamp
  
  // Relations
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  itemViews    ItemView[]
  itemRatings  ItemRating[]
  itemFeedback ItemFeedback[]

  @@map("menu_items")
}

model ItemView {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  sessionId String   @map("session_id") @db.Text
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamp

  // Relations
  menuItem  MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("item_views")
}

model ItemRating {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  sessionId String   @map("session_id") @db.Text
  rating    Int      @db.Integer // Validated as 1-5 in business logic
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  // Relations
  menuItem  MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([itemId, sessionId])
  @@map("item_ratings")
}

model ItemFeedback {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  sessionId String   @map("session_id") @db.Text
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  // Relations
  menuItem  MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("item_feedback")
}

model GeneralFeedback {
  id        Int      @id @default(autoincrement())
  sessionId String   @map("session_id") @db.Text
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  // Relations
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("general_feedback")
}

model Session {
  id              String            @id @db.Text // Client-side or backend generated random UUID
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp
  expiresAt       DateTime          @map("expires_at") @db.Timestamp
  ipHash          String            @map("ip_hash") @db.Text
  userAgent       String            @map("user_agent") @db.Text
  
  // Relations
  qrScans         QrScan[]
  itemViews       ItemView[]
  itemRatings     ItemRating[]
  itemFeedback    ItemFeedback[]
  generalFeedback GeneralFeedback[]

  @@map("sessions")
}